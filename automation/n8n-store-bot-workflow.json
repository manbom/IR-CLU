      "typeVersion": 2.2,
      "position": [-400, 500],
      "parameters": {
        "conditions": {
          "options": { "caseSensitive": true, "leftValue": "", "typeValidation": "loose" },
          "conditions": [{ "leftValue": "={{ $json.awaitingOrderId }}", "rightValue": "", "operator": { "type": "string", "operation": "notEmpty" } }],
