{
  "name": "IR-CLU — ربات فروش (احراز هویت + هوش مصنوعی + پرداخت کارت‌به‌کارت)",
  "nodes": [
    {
      "id": "tg-trigger",
      "name": "پیام جدید در ربات فروش",
      "type": "n8n-nodes-base.telegramTrigger",
      "typeVersion": 1.1,
      "position": [-1600, 0],
      "parameters": { "updates": ["message"] },
      "credentials": { "telegramApi": { "id": "PLACEHOLDER", "name": "Telegram Store Bot" } }
    },
    {
      "id": "code-classify",
      "name": "تشخیص نوع پیام",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [-1360, 0],
      "parameters": {
        "jsCode": "const msg = $json.message || {};\nconst chatId = msg.chat?.id;\nconst username = msg.from?.username || \"\";\nconst firstName = msg.from?.first_name || \"\";\nconst text = (msg.text || \"\").trim();\nconst adminChatId = String($env.ADMIN_CHAT_ID);\n\nlet kind = \"free_text\";\nlet slug = null;\nlet decisionAction = null;\nlet decisionOrderId = null;\n\nif (msg.contact) {\n  kind = \"contact\";\n} else if (/^\\/start\\s+\\S+/.test(text)) {\n  kind = \"start_product\";\n  slug = text.match(/^\\/start\\s+(\\S+)/)[1];\n} else if (msg.photo && msg.photo.length) {\n  kind = \"photo_receipt\";\n} else if (String(chatId) === adminChatId && /^(تایید|رد)\\s+(ORDER-\\S+)/.test(text)) {\n  kind = \"admin_decision\";\n  const m = text.match(/^(تایید|رد)\\s+(ORDER-\\S+)/);\n  decisionAction = m[1] === \"تایید\" ? \"approve\" : \"reject\";\n  decisionOrderId = m[2];\n}\n\nconst photo = msg.photo ? msg.photo[msg.photo.length - 1] : null;\n\nreturn [{\n  json: {\n    kind, chatId, username, firstName, text, slug,\n    decisionAction, decisionOrderId,\n    photoFileId: photo ? photo.file_id : null,\n  },\n}];"
      }
    },
    {
      "id": "switch-kind",
      "name": "مسیر بر اساس نوع پیام",
      "type": "n8n-nodes-base.switch",
      "typeVersion": 3.2,
      "position": [-1120, 0],
      "parameters": {
        "rules": {
          "values": [
            { "conditions": { "combinator": "and", "conditions": [{ "leftValue": "={{ $json.kind }}", "rightValue": "contact", "operator": { "type": "string", "operation": "equals" } }] }, "outputKey": "contact" },
            { "conditions": { "combinator": "and", "conditions": [{ "leftValue": "={{ $json.kind }}", "rightValue": "start_product", "operator": { "type": "string", "operation": "equals" } }] }, "outputKey": "start_product" },
            { "conditions": { "combinator": "and", "conditions": [{ "leftValue": "={{ $json.kind }}", "rightValue": "photo_receipt", "operator": { "type": "string", "operation": "equals" } }] }, "outputKey": "photo_receipt" },
            { "conditions": { "combinator": "and", "conditions": [{ "leftValue": "={{ $json.kind }}", "rightValue": "admin_decision", "operator": { "type": "string", "operation": "equals" } }] }, "outputKey": "admin_decision" },
            { "conditions": { "combinator": "and", "conditions": [{ "leftValue": "={{ $json.kind }}", "rightValue": "free_text", "operator": { "type": "string", "operation": "equals" } }] }, "outputKey": "free_text" }
          ]
        },
        "options": {}
      }
    },

    {
      "id": "sheets-save-phone",
      "name": "ذخیره شماره تلفن",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4.5,
      "position": [-880, -600],
      "parameters": {
        "operation": "appendOrUpdate",
        "documentId": { "mode": "list", "value": "PLACEHOLDER_SPREADSHEET_ID" },
        "sheetName": { "mode": "name", "value": "Customers" },
        "columns": {
          "mappingMode": "defineBelow",
          "matchingColumns": ["telegram_user_id"],
          "value": {
            "telegram_user_id": "={{ $json.chatId }}",
            "username": "={{ $json.username }}",
            "phone": "={{ $json.message.contact.phone_number }}",
            "created_at": "={{ new Date().toISOString() }}"
          }
        }
      },
      "credentials": { "googleSheetsOAuth2Api": { "id": "PLACEHOLDER", "name": "Google Sheets (IR-CLU Store)" } }
    },
    {
      "id": "sheets-read-customer-after-phone",
      "name": "خواندن وضعیت مشتری",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4.5,
      "position": [-640, -600],
      "parameters": {
        "operation": "read",
        "documentId": { "mode": "list", "value": "PLACEHOLDER_SPREADSHEET_ID" },
        "sheetName": { "mode": "name", "value": "Customers" }
      },
      "credentials": { "googleSheetsOAuth2Api": { "id": "PLACEHOLDER", "name": "Google Sheets (IR-CLU Store)" } }
    },
    {
      "id": "code-resume-after-phone",
      "name": "ادامه دادن بعد از احراز هویت",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [-400, -600],
      "parameters": {
        "jsCode": "const chatId = $('تشخیص نوع پیام').first().json.chatId;\nconst username = $('تشخیص نوع پیام').first().json.username;\nconst firstName = $('تشخیص نوع پیام').first().json.firstName;\n\nconst rows = $input.all().map((i) => i.json);\nconst row = rows.find((r) => String(r.telegram_user_id) === String(chatId));\nconst pending = row?.pending_state || \"\";\nconst m = pending.match(/^awaiting_product:(.+)$/);\n\nreturn [{\n  json: { chatId, username, firstName, resumeSlug: m ? m[1] : null },\n}];"
      }
    },
    {
      "id": "tg-phone-saved",
      "name": "تأیید ثبت شماره",
      "type": "n8n-nodes-base.telegram",
      "typeVersion": 1.2,
      "position": [-160, -700],
      "parameters": {
        "resource": "message",
        "operation": "sendMessage",
        "chatId": "={{ $json.chatId }}",
        "text": "ممنون، شماره‌ات ثبت شد ✅",
        "replyMarkup": "removeKeyboard"
      },
      "credentials": { "telegramApi": { "id": "PLACEHOLDER", "name": "Telegram Store Bot" } }
    },
    {
      "id": "if-has-resume-slug",
      "name": "محصولی در انتظار بود؟",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.2,
      "position": [-160, -500],
      "parameters": {
        "conditions": {
          "options": { "caseSensitive": true, "leftValue": "", "typeValidation": "loose" },
          "conditions": [{ "leftValue": "={{ $json.resumeSlug }}", "rightValue": "", "operator": { "type": "string", "operation": "notEmpty" } }],
          "combinator": "and"
        }
      }
    },

    {
      "id": "sheets-read-customers-for-check",
      "name": "خواندن مشتریان",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4.5,
      "position": [-880, -200],
      "parameters": {
        "operation": "read",
        "documentId": { "mode": "list", "value": "PLACEHOLDER_SPREADSHEET_ID" },
        "sheetName": { "mode": "name", "value": "Customers" }
      },
      "credentials": { "googleSheetsOAuth2Api": { "id": "PLACEHOLDER", "name": "Google Sheets (IR-CLU Store)" } }
    },
    {
      "id": "code-check-phone",
      "name": "بررسی احراز هویت",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [-640, -200],
      "parameters": {
        "jsCode": "const t = $('تشخیص نوع پیام').first().json;\nconst rows = $input.all().map((i) => i.json);\nconst row = rows.find((r) => String(r.telegram_user_id) === String(t.chatId));\n\nreturn [{\n  json: { ...t, hasPhone: !!(row && row.phone) },\n}];"
      }
    },
    {
      "id": "if-has-phone",
      "name": "شماره قبلاً ثبت شده؟",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.2,
      "position": [-400, -200],
      "parameters": {
        "conditions": {
          "options": { "caseSensitive": true, "leftValue": "", "typeValidation": "loose" },
          "conditions": [{ "leftValue": "={{ $json.hasPhone }}", "rightValue": true, "operator": { "type": "boolean", "operation": "true", "singleValue": true } }],
          "combinator": "and"
        }
      }
    },
    {
      "id": "sheets-save-pending-slug",
      "name": "ذخیره محصول در انتظار",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4.5,
      "position": [-160, -100],
      "parameters": {
        "operation": "appendOrUpdate",
        "documentId": { "mode": "list", "value": "PLACEHOLDER_SPREADSHEET_ID" },
        "sheetName": { "mode": "name", "value": "Customers" },
        "columns": {
          "mappingMode": "defineBelow",
          "matchingColumns": ["telegram_user_id"],
          "value": {
            "telegram_user_id": "={{ $json.chatId }}",
            "pending_state": "=awaiting_product:{{ $json.slug }}"
          }
        }
      },
      "credentials": { "googleSheetsOAuth2Api": { "id": "PLACEHOLDER", "name": "Google Sheets (IR-CLU Store)" } }
    },
    {
      "id": "tg-request-phone",
      "name": "درخواست شماره تلفن",
      "type": "n8n-nodes-base.telegram",
      "typeVersion": 1.2,
      "position": [80, -100],
