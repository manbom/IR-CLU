      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [-640, 500],
      "parameters": {
        "jsCode": "const t = $('تشخیص نوع پیام').first().json;\nconst rows = $input.all().map((i) => i.json);\nconst row = rows.find((r) => String(r.telegram_user_id) === String(t.chatId));\nconst pending = row?.pending_state || \"\";\nconst m = pending.match(/^awaiting_requirements:(.+)$/);\n\nreturn [{\n  json: { ...t, awaitingOrderId: m ? m[1] : null },\n}];"
      }
    },
    {
