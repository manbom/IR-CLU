        "text": "برای ادامه، اول لطفاً شماره تلفنت رو با دکمه زیر به اشتراک بذار 👇",
        "replyMarkup": "keyboard",
        "keyboard": {
          "rows": [
            { "row": { "buttons": [{ "text": "📱 اشتراک‌گذاری شماره تلفن", "additionalFields": { "requestContact": true } }] } }
          ]
        },
        "additionalFields": { "resize_keyboard": true, "one_time_keyboard": true }
      },
      "credentials": { "telegramApi": { "id": "PLACEHOLDER", "name": "Telegram Store Bot" } }
    },

    {
      "id": "sheets-read-products",
      "name": "خواندن محصولات",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4.5,
      "position": [80, 100],
      "parameters": {
        "operation": "read",
        "documentId": { "mode": "list", "value": "PLACEHOLDER_SPREADSHEET_ID" },
        "sheetName": { "mode": "name", "value": "Products" }
      },
      "credentials": { "googleSheetsOAuth2Api": { "id": "PLACEHOLDER", "name": "Google Sheets (IR-CLU Store)" } }
    },
    {
      "id": "code-find-product",
      "name": "پیدا کردن محصول",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [320, 100],
      "parameters": {
        "jsCode": "const slug = $json.slug || $json.resumeSlug;\nconst chatId = $json.chatId;\nconst username = $json.username;\n\nconst rows = $input.all().map((i) => i.json);\nconst product = rows.find((r) => r.slug === slug && String(r.active).toLowerCase() === 'true');\n\nreturn [{ json: { found: !!product, chatId, username, slug, product: product || null } }];"
      }
    },
    {
      "id": "if-product-found",
      "name": "محصول پیدا شد؟",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.2,
      "position": [560, 100],
      "parameters": {
        "conditions": {
          "options": { "caseSensitive": true, "leftValue": "", "typeValidation": "loose" },
          "conditions": [{ "leftValue": "={{ $json.found }}", "rightValue": true, "operator": { "type": "boolean", "operation": "true", "singleValue": true } }],
          "combinator": "and"
        }
      }
    },
    {
      "id": "tg-not-found",
      "name": "محصول پیدا نشد",
      "type": "n8n-nodes-base.telegram",
      "typeVersion": 1.2,
      "position": [800, 220],
      "parameters": {
        "resource": "message",
        "operation": "sendMessage",
        "chatId": "={{ $json.chatId }}",
        "text": "این محصول در دسترس نیست. از صفحه‌ی فروشگاه (irclu.com/store) دوباره امتحان کن."
      },
      "credentials": { "telegramApi": { "id": "PLACEHOLDER", "name": "Telegram Store Bot" } }
    },
    {
      "id": "code-create-order",
      "name": "ساخت سفارش جدید",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [800, -20],
      "parameters": {
        "jsCode": "const orderId = `ORDER-${Date.now()}-${Math.floor(Math.random() * 9000 + 1000)}`;\nreturn [{ json: { ...$json, orderId } }];"
      }
    },
    {
      "id": "sheets-append-order",
      "name": "ثبت سفارش (در انتظار نیازها)",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4.5,
      "position": [1040, -20],
      "parameters": {
        "operation": "append",
        "documentId": { "mode": "list", "value": "PLACEHOLDER_SPREADSHEET_ID" },
        "sheetName": { "mode": "name", "value": "Orders" },
        "columns": {
          "mappingMode": "defineBelow",
          "value": {
            "order_id": "={{ $json.orderId }}",
            "telegram_user_id": "={{ $json.chatId }}",
            "telegram_username": "={{ $json.username }}",
            "product_slug": "={{ $json.slug }}",
            "amount": "={{ $json.product.price }}",
            "requirements_summary": "",
            "status": "awaiting_requirements",
            "receipt_file_id": "",
            "created_at": "={{ new Date().toISOString() }}",
            "reviewed_at": "",
            "expires_at": "",
            "renewal_notified": "false"
          }
        }
      },
      "credentials": { "googleSheetsOAuth2Api": { "id": "PLACEHOLDER", "name": "Google Sheets (IR-CLU Store)" } }
    },
    {
      "id": "sheets-set-pending-requirements",
      "name": "ثبت وضعیت در انتظار نیازها",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4.5,
      "position": [1280, -20],
      "parameters": {
        "operation": "appendOrUpdate",
        "documentId": { "mode": "list", "value": "PLACEHOLDER_SPREADSHEET_ID" },
        "sheetName": { "mode": "name", "value": "Customers" },
        "columns": {
          "mappingMode": "defineBelow",
          "matchingColumns": ["telegram_user_id"],
          "value": {
            "telegram_user_id": "={{ $json.chatId }}",
            "pending_state": "=awaiting_requirements:{{ $json.orderId }}"
          }
        }
      },
      "credentials": { "googleSheetsOAuth2Api": { "id": "PLACEHOLDER", "name": "Google Sheets (IR-CLU Store)" } }
    },
    {
      "id": "tg-ask-requirements",
      "name": "درخواست توضیح نیازها",
      "type": "n8n-nodes-base.telegram",
      "typeVersion": 1.2,
      "position": [1520, -20],
      "parameters": {
        "resource": "message",
        "operation": "sendMessage",
        "chatId": "={{ $json.chatId }}",
        "text": "=✅ {{ $json.product.title }}\nقیمت: {{ Number($json.product.price).toLocaleString('fa-IR') }} تومان (ماهانه)\n\nحالا با زبان خودت برام بنویس دقیقاً چه نیازی داری (نوع کسب‌وکار، چه کاری باید انجام بشه، هر جزئیات مهمی). هوش مصنوعی ما همین الان خلاصه‌اش می‌کنه و می‌فرسته پیش تیم ما."
      },
      "credentials": { "telegramApi": { "id": "PLACEHOLDER", "name": "Telegram Store Bot" } }
    },

    {
