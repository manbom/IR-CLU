      }
    },
    {
      "id": "http-claude-summarize",
      "name": "خلاصه‌سازی نیازها با Claude",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [-160, 400],
      "parameters": {
        "method": "POST",
        "url": "https://api.anthropic.com/v1/messages",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendHeaders": true,
        "headerParameters": { "parameters": [{ "name": "anthropic-version", "value": "2023-06-01" }, { "name": "content-type", "value": "application/json" }] },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({\n  model: \"claude-sonnet-5\",\n  max_tokens: 500,\n  system: \"یک تحلیل‌گر نیازمندی مشتری برای استودیوی اتوماسیون IR-CLU هستی. پیام مشتری را در چند خط خلاصه‌ی فارسی، شفاف و کاربردی برای تیم فنی بازنویسی کن؛ نوع کسب‌وکار، خواسته اصلی، و هر جزئیات مهمی که ذکر کرده را نگه دار. فقط خلاصه را بنویس، بدون مقدمه.\",\n  messages: [{ role: \"user\", content: $json.text }]\n}) }}"
      },
      "credentials": { "httpHeaderAuth": { "id": "PLACEHOLDER", "name": "Anthropic API Key (x-api-key)" } }
    },
    {
      "id": "sheets-update-requirements",
      "name": "ثبت خلاصه نیازها در سفارش",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4.5,
      "position": [80, 400],
      "parameters": {
        "operation": "update",
        "documentId": { "mode": "list", "value": "PLACEHOLDER_SPREADSHEET_ID" },
        "sheetName": { "mode": "name", "value": "Orders" },
        "columns": {
          "mappingMode": "defineBelow",
          "matchingColumns": ["order_id"],
          "value": {
            "order_id": "={{ $('بررسی انتظار نیازها').first().json.awaitingOrderId }}",
            "requirements_summary": "={{ $json.content[0].text }}",
            "status": "awaiting_payment"
          }
        }
      },
      "credentials": { "googleSheetsOAuth2Api": { "id": "PLACEHOLDER", "name": "Google Sheets (IR-CLU Store)" } }
    },
    {
